{
  "buildCommand": "cd frontend && npm install && npm run build",
  "outputDirectory": "frontend/dist",
  "framework": "vite",
  "installCommand": "pip install -r backend/requirements.txt && pip install numpy pandas scikit-learn && npm install --prefix frontend",
  "functions": {
    "api/index.py": {
      "memory": 3008,
      "maxDuration": 60
    }
  },
  "env": {
    "VITE_API_URL": {
      "default": ""
    }
  },
  "envVars": {
    "PYTHONUNBUFFERED": "1"
  },
  "routes": [
    {
      "src": "/api/(.*)",
      "dest": "api/index.py"
    },
    {
      "src": "/(.*)",
      "dest": "frontend/dist/$1"
    },
    {
      "src": "/(.*)(?<!/.*)",
      "dest": "/frontend/dist/index.html"
    }
  ]
}
